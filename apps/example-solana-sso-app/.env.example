# Used by BOTH the Vite frontend and the example backend (server/index.mjs).
# The backend reads these via `node --env-file=.env`.
VITE_ALIEN_SSO_BASE_URL=https://sso.develop.alien-api.com
VITE_ALIEN_PROVIDER_ADDRESS=

# Optional: backend port (defaults to 8787; Vite proxies /api here).
# PORT=8787
