{
  "name": "@alien-id/sso-agent-id",
  "version": "2.1.1",
  "description": "Verify Alien Agent ID tokens — Ed25519 token verification for Node.js services",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alien-id/sso-sdk-js.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "release": "npm publish --access public"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.12.4",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "tsdown": "0.22.2"
  },
  "engines": {
    "node": ">=18"
  }
}
