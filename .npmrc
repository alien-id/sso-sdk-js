# Supply-chain hardening for the npm CLI path (publish workflow + any
# consumer that installs with npm). See SECURITY.md.

# 3-day cooldown on version resolution: `npm install` won't resolve a version
# published less than 3 days ago. (Note: `npm ci` replays the lockfile verbatim
# and does NOT re-check age — Renovate's matching cooldown gates the lockfile.)
# Every 2025-2026 npm worm was detected within minutes; a 3-day gate
# neutralizes the entire class. Requires npm >= 11.10.0 (see mise.toml).
# Vulnerability fixes are pulled in out-of-band, so emergency CVEs are
# not held up by this.
min-release-age=3

# Kills the preinstall/postinstall vector used by ua-parser-js, Nx,
# Axios, Bitwarden CLI, and Shai-Hulud v1/v2.
ignore-scripts=true

# Exact-version installs (no ^ or ~). Floats are how poisoned patches
# reach consumers without code review.
save-exact=true

# Quality-of-life + enforcement.
fund=false
audit-level=high
engine-strict=true

registry=https://registry.npmjs.org/
